+                 list(data = z1, dimVar = 1:2, freqVar = 3, maxN = 5), 
+                 list(data = z2b, dimVar = 1:2, freqVar = 3, maxN = 5), 
+                 list(data = z2, dimVar = 1:4, freqVar = 5, maxN = 1)))
