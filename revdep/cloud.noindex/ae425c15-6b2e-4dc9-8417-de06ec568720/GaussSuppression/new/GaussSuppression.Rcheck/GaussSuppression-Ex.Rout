> ### Name: LazyLinkedTables
> ### Title: Linked tables by full 'GaussSuppressionFromData' iterations
> ### Aliases: LazyLinkedTables
> 
> ### ** Examples
> 
> 
> z1 <- SSBtoolsData("z1")
> z2 <- SSBtoolsData("z2")
> z2b <- z2[3:5]  # As in ChainedSuppression example 
> names(z2b)[1] <- "region"
> 
> # The two region hierarchies as two linked tables
> a <- LazyLinkedTables(z2, freqVar = 5, withinArg = list(
+        list(dimVar = c(1, 2, 4)), 
+        list(dimVar = c(1, 3, 4))))
