> # 'A' 'annet'/'arbeid' suppressed in b[[1]], since suppressed in b[[3]].
> b <- SuppressLinkedTables(fun = SuppressSmallCounts,
+               linkedGauss = "consistent",  
+               recordAware = FALSE,
