> 
> ### Name: post_medx
> ### Title: Posterior Distribution of Minimum X% Effective Dose
> ### Aliases: post_medx post_medx.dreamer_bma post_medx.dreamer_mcmc
> 
> ### ** Examples
> 
> set.seed(888)
> data <- dreamer_data_linear(
+   n_cohorts = c(20, 20, 20),
+   dose = c(0, 3, 10),
+   b1 = 1,
+   b2 = 3,
+   sigma = 5
+ )
> 
> # Bayesian model averaging
> output <- dreamer_mcmc(
+  data = data,
+  n_adapt = 1e3,
+  n_burn = 1e3,
+  n_iter = 1e3,
+  n_chains = 2,
+  silent = FALSE,
+  mod_linear = model_linear(
+    mu_b1 = 0,
+    sigma_b1 = 1,
+    mu_b2 = 0,
+    sigma_b2 = 1,
+    shape = 1,
+    rate = .001,
+    w_prior = 1 / 2
+  ),
+  mod_quad = model_quad(
+    mu_b1 = 0,
