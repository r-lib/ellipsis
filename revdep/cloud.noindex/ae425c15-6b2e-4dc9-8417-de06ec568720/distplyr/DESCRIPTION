Type: Package
Package: distplyr
Title: Manipulate and Combine Probability Distributions
Version: 0.2.0
Authors@R: c(
    person("Vincenzo", "Coia", email = "vincenzo.coia@gmail.com", 
           role = c("aut", "cre", "cph")),
    person("Amogh", "Joshi", role = "ctb"),
